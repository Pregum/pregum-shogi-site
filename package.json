{
  "name": "pregum-shogi-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build && concurrently -k -n vite,worker \"vite\" \"wrangler dev --port 8787\"",
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "deploy": "vite build && wrangler deploy"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.106.0"
  }
}
